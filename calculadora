&lt;script>
'use strict';
var soDig = function (s) { return String(s == null ? '' : s).split('').filter(function (c) { return c >= '0' &amp;&amp; c &lt;= '9'; }).join(''); };
var fmtBRL = function (v) { return 'R$ ' + Math.round(v).toLocaleString('pt-BR'); };
var st = { ticket: 0, pac: 0, tempo: 0, plano: 0, dieta: '', ticketNovo: 0, pacNovo: 0, aba: 'mes' };

var $ = function (id) { return document.getElementById(id); };
var elTicket = $('pj-ticket'), elPac = $('pj-pac'), elTempo = $('pj-tempo'), elPlano = $('pj-plano');
var rT = $('pj-r-ticket'), rP = $('pj-r-pac');

function fill(el) {
  var min = +el.min, max = +el.max, w = max > min ? (+el.value - min) / (max - min) * 100 : 0;
  el.style.backgroundImage = 'linear-gradient(90deg, var(--blue) ' + w + '%, var(--track) ' + w + '%)';
}

function recalc() {
  var t = st.ticket, p = st.pac;
  var valido = t > 0 &amp;&amp; p > 0;

  /* ---- cenário atual ---- */
  $('pj-fat-hoje').innerHTML = valido ? fmtBRL(t * p * 4) + ' &lt;small>/mês&lt;/small>' : '—';
  var minHoje = (valido &amp;&amp; st.tempo > 0) ? p * st.tempo + (st.dieta === 'nao' ? p * (st.plano || 0) : 0) : 0;
  var horaHoje = minHoje > 0 ? (t * p) / (minHoje / 60) : 0;
  if (horaHoje > 0) {
    var hh = Math.floor(minHoje / 60), mm = minHoje % 60;
    $('pj-hora-hoje').innerHTML = fmtBRL(horaHoje) + ' &lt;small>/hora&lt;/small>';
    $('pj-hora-hoje-det').textContent = hh + 'h' + (mm ? (mm &lt; 10 ? '0' : '') + mm : '') + ' de trabalho por semana' +
      (st.dieta === 'nao' &amp;&amp; st.plano > 0 ? ' — consultas + elaboração dos planos alimentares' : '');
  } else {
    $('pj-hora-hoje').textContent = '—';
    $('pj-hora-hoje-det').textContent = 'preencha o tempo de consulta acima';
  }

  /* ---- trava / libera projeção e comparação ---- */
  $('pj-card-proj').classList.toggle('trava', !valido);
  $('pj-card-comp').classList.toggle('trava', !valido);
  $('pj-lock').textContent = valido ? '' : 'Preencha seus números ao lado para liberar a projeção.';
  rT.disabled = !valido;
  rP.disabled = !valido;

  if (!valido) {
    $('pj-v-ticket').textContent = '—'; $('pj-v-pac').textContent = '—';
    $('pj-min-t').textContent = '—'; $('pj-max-t').textContent = '—';
    $('pj-min-p').textContent = '—'; $('pj-max-p').textContent = '—';
    $('pj-fat-novo').textContent = '—'; $('pj-sub').textContent = '';
    $('pj-hora-nova').textContent = '—';
    $('pj-bar-a').style.width = '0'; $('pj-bar-n').style.width = '0';
    $('pj-lbl-a').textContent = '—'; $('pj-lbl-n').textContent = '—';
    $('pj-t1-v').textContent = '—'; $('pj-t2-v').textContent = '—'; $('pj-t3-v').textContent = '—';
    $('pj-hbar-a').style.width = '0'; $('pj-hbar-n').style.width = '0';
    $('pj-hlbl-a').textContent = '—'; $('pj-hlbl-n').textContent = '—';
    $('pj-frase').innerHTML = 'Preencha seus números de hoje e arraste os controles para ver a sua projeção.';
    fill(rT); fill(rP);
    ajustaAltura();
    return;
  }

  /* ---- faixas dos controles (teto: R$ 1.000 e 30 pacientes) ---- */
  var tkMax = Math.max(1000, t + 200);
  var pcMax = Math.max(30, p + 5);
  if (!(st.ticketNovo >= t &amp;&amp; st.ticketNovo &lt;= tkMax)) st.ticketNovo = t;
  if (!(st.pacNovo >= p &amp;&amp; st.pacNovo &lt;= pcMax)) st.pacNovo = p;
  rT.min = t; rT.max = tkMax; rT.step = (t >= 1000 ? 25 : 5); rT.value = st.ticketNovo;
  rP.min = p; rP.max = pcMax; rP.step = 1; rP.value = st.pacNovo;
  $('pj-min-t').textContent = fmtBRL(t); $('pj-max-t').textContent = fmtBRL(tkMax);
  $('pj-min-p').textContent = p; $('pj-max-p').textContent = pcMax;
  fill(rT); fill(rP);

  /* ---- projeção ---- */
  var fa = t * p * 4, fn = st.ticketNovo * st.pacNovo * 4;
  var dm = fn - fa;
  var pc = fa > 0 ? Math.round((fn / fa - 1) * 100) : 0;
  $('pj-v-ticket').textContent = fmtBRL(st.ticketNovo);
  $('pj-v-pac').textContent = st.pacNovo + (st.pacNovo === 1 ? ' paciente' : ' pacientes');
  $('pj-fat-novo').textContent = fmtBRL(fn);
  $('pj-sub').textContent = 'com consulta a ' + fmtBRL(st.ticketNovo) + ' e ' + st.pacNovo + ' pacientes por semana';

  /* hora projetada: dieta entregue na hora (sem levar plano para casa) */
  var minNovo = st.tempo > 0 ? st.pacNovo * st.tempo : 0;
  var horaNova = minNovo > 0 ? (st.ticketNovo * st.pacNovo) / (minNovo / 60) : 0;
  $('pj-hora-nova').innerHTML = horaNova > 0 ? fmtBRL(horaNova) + ' &lt;small>/hora&lt;/small>' : '—';

  /* ---- comparação ---- */
  var ano = st.aba === 'ano';
  var A = fa * (ano ? 12 : 1), N = fn * (ano ? 12 : 1), D = N - A;
  var maxV = Math.max(A, N, 1);
  $('pj-bar-a').style.width = 'calc((100% - 104px) * ' + (A / maxV).toFixed(4) + ')';
  $('pj-bar-n').style.width = 'calc((100% - 104px) * ' + (N / maxV).toFixed(4) + ')';
  $('pj-lbl-a').textContent = fmtBRL(A);
  $('pj-lbl-n').textContent = fmtBRL(N);
  var cls = D > 0 ? 't-v pos' : 't-v';
  if (ano) {
    $('pj-t1-l').textContent = 'Faturamento anual hoje'; $('pj-t1-v').textContent = fmtBRL(A); $('pj-t1-v').className = 't-v';
    $('pj-t2-l').textContent = 'Faturamento anual projetado'; $('pj-t2-v').textContent = fmtBRL(N); $('pj-t2-v').className = 't-v';
    $('pj-t3-l').textContent = 'A mais em 1 ano'; $('pj-t3-v').textContent = (D >= 0 ? '+' : '−') + fmtBRL(Math.abs(D)); $('pj-t3-v').className = cls;
  } else {
    $('pj-t1-l').textContent = 'A mais por mês'; $('pj-t1-v').textContent = (D >= 0 ? '+' : '−') + fmtBRL(Math.abs(D)); $('pj-t1-v').className = cls;
    $('pj-t2-l').textContent = 'Crescimento'; $('pj-t2-v').textContent = (pc >= 0 ? '+' : '') + pc + '%'; $('pj-t2-v').className = cls;
    $('pj-t3-l').textContent = 'A mais em 12 meses'; $('pj-t3-v').textContent = (D >= 0 ? '+' : '−') + fmtBRL(Math.abs(dm * 12)); $('pj-t3-v').className = cls;
  }

  /* comparação do valor da hora */
  if (horaHoje > 0 &amp;&amp; horaNova > 0) {
    var maxH = Math.max(horaHoje, horaNova, 1);
    $('pj-hbar-a').style.width = 'calc((100% - 104px) * ' + (horaHoje / maxH).toFixed(4) + ')';
    $('pj-hbar-n').style.width = 'calc((100% - 104px) * ' + (horaNova / maxH).toFixed(4) + ')';
    $('pj-hlbl-a').textContent = fmtBRL(horaHoje) + ' /h';
    $('pj-hlbl-n').textContent = fmtBRL(horaNova) + ' /h';
    $('pj-hora-comp-det').textContent = 'projetado: entregando a dieta na hora, direto na consulta';
  } else {
    $('pj-hbar-a').style.width = '0'; $('pj-hbar-n').style.width = '0';
    $('pj-hlbl-a').textContent = '—'; $('pj-hlbl-n').textContent = '—';
    $('pj-hora-comp-det').textContent = 'preencha o tempo de consulta para comparar o valor da sua hora';
  }

  /* frase */
  var frase;
  if (dm > 0) {
    frase = ano
      ? 'Em 12 meses: de &lt;b>' + fmtBRL(A) + '&lt;/b> para &lt;b>' + fmtBRL(N) + '&lt;/b> — &lt;b>' + fmtBRL(D) + ' a mais em um ano&lt;/b> com as estratégias implementadas.'
      : 'Com consulta a &lt;b>' + fmtBRL(st.ticketNovo) + '&lt;/b> e &lt;b>' + st.pacNovo + ' pacientes por semana&lt;/b>, você sai de &lt;b>' + fmtBRL(fa) + '&lt;/b> para &lt;b>' + fmtBRL(fn) + ' por mês&lt;/b> — &lt;b>' + fmtBRL(dm) + ' a mais todo mês&lt;/b>.';
    if (horaHoje > 0 &amp;&amp; horaNova > horaHoje)
      frase += ' E a sua hora sai de &lt;b>' + fmtBRL(horaHoje) + '&lt;/b> para &lt;b>' + fmtBRL(horaNova) + '&lt;/b>, já entregando a dieta na hora.';
  } else {
    frase = 'Arraste os controles acima e veja o seu faturamento crescer.';
  }
  $('pj-frase').innerHTML = frase;
  ajustaAltura();
}

var pend = false;
function recalcRAF() {
  if (pend) return;
  pend = true;
  requestAnimationFrame(function () { pend = false; recalc(); });
}

elTicket.addEventListener('input', function () {
  var d = soDig(elTicket.value).slice(0, 6);
  elTicket.value = d ? Number(d).toLocaleString('pt-BR') : '';
  var novo = parseInt(d, 10) || 0;
  if (novo !== st.ticket) { st.ticket = novo; st.ticketNovo = novo; }
  recalc();
});
elPac.addEventListener('input', function () {
  elPac.value = soDig(elPac.value).slice(0, 3);
  var novo = parseInt(elPac.value, 10) || 0;
  if (novo !== st.pac) { st.pac = novo; st.pacNovo = novo; }
  recalc();
});
elTempo.addEventListener('input', function () {
  elTempo.value = soDig(elTempo.value).slice(0, 3);
  st.tempo = parseInt(elTempo.value, 10) || 0;
  recalc();
});
elPlano.addEventListener('input', function () {
  elPlano.value = soDig(elPlano.value).slice(0, 3);
  st.plano = parseInt(elPlano.value, 10) || 0;
  recalc();
});
var daSim = $('pj-da-sim'), daNao = $('pj-da-nao');
function setDieta(v) {
  st.dieta = v;
  daSim.classList.toggle('on', v === 'sim');
  daNao.classList.toggle('on', v === 'nao');
  /* o campo do plano ocupa o espaço desde o início (visibility) — nada salta na página */
  $('pj-campo-plano').classList.toggle('reserva-oculta', v !== 'nao');
  recalc();
}
daSim.addEventListener('click', function () { setDieta('sim'); });
daNao.addEventListener('click', function () { setDieta('nao'); });

rT.addEventListener('input', function () { st.ticketNovo = +rT.value; recalcRAF(); });
rP.addEventListener('input', function () { st.pacNovo = +rP.value; recalcRAF(); });
var tm = $('pj-tab-mes'), ta = $('pj-tab-ano');
function setAba(a) { st.aba = a; tm.classList.toggle('on', a === 'mes'); ta.classList.toggle('on', a === 'ano'); recalc(); }
tm.addEventListener('click', function () { setAba('mes'); });
ta.addEventListener('click', function () { setAba('ano'); });

/* Altura do iframe: estável por construção (layout completo desde o início) e
   sincronizada continuamente com a página-mãe (observador + verificação periódica). */
function ajustaAltura() {
  if (!window.frameElement) return;
  requestAnimationFrame(function () {
    var h = document.documentElement.scrollHeight;
    if (Math.abs((parseInt(window.frameElement.style.height, 10) || 0) - h) > 2)
      window.frameElement.style.height = h + 'px';
  });
}
window.addEventListener('load', ajustaAltura);
window.addEventListener('resize', ajustaAltura);
if (typeof ResizeObserver !== 'undefined') new ResizeObserver(ajustaAltura).observe(document.body);
setInterval(ajustaAltura, 700);

recalc();
&lt;/script>
&lt;/body>
&lt;/html>
"></iframe>
</div>
