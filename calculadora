    &lt;/div>
    &lt;div class=&quot;barras&quot;>
      &lt;div class=&quot;barra-row&quot;>&lt;span class=&quot;barra-nome&quot;>Hoje&lt;/span>&lt;div class=&quot;barra-line&quot;>&lt;div class=&quot;barra atual&quot; id=&quot;pj-bar-a&quot; style=&quot;width:0&quot;>&lt;/div>&lt;span class=&quot;barra-lbl&quot; id=&quot;pj-lbl-a&quot;>—&lt;/span>&lt;/div>&lt;/div>
      &lt;div class=&quot;barra-row&quot;>&lt;span class=&quot;barra-nome&quot;>Projetado&lt;/span>&lt;div class=&quot;barra-line&quot;>&lt;div class=&quot;barra nova&quot; id=&quot;pj-bar-n&quot; style=&quot;width:0&quot;>&lt;/div>&lt;span class=&quot;barra-lbl&quot; id=&quot;pj-lbl-n&quot;>—&lt;/span>&lt;/div>&lt;/div>
