      &lt;div class=&quot;tile&quot;>&lt;div class=&quot;t-l&quot; id=&quot;pj-t2-l&quot;>Crescimento&lt;/div>&lt;div class=&quot;t-v&quot; id=&quot;pj-t2-v&quot;>—&lt;/div>&lt;/div>
      &lt;div class=&quot;tile&quot;>&lt;div class=&quot;t-l&quot; id=&quot;pj-t3-l&quot;>A mais em 12 meses&lt;/div>&lt;div class=&quot;t-v&quot; id=&quot;pj-t3-v&quot;>—&lt;/div>&lt;/div>
    &lt;/div>
    &lt;div class=&quot;sub-comp&quot;>O valor da sua hora&lt;/div>
    &lt;div class=&quot;barras&quot;>
      &lt;div class=&quot;barra-row&quot;>&lt;span class=&quot;barra-nome&quot;>Hoje&lt;/span>&lt;div class=&quot;barra-line&quot;>&lt;div class=&quot;barra atual&quot; id=&quot;pj-hbar-a&quot; style=&quot;width:0&quot;>&lt;/div>&lt;span class=&quot;barra-lbl&quot; id=&quot;pj-hlbl-a&quot;>—&lt;/span>&lt;/div>&lt;/div>
      &lt;div class=&quot;barra-row&quot;>&lt;span class=&quot;barra-nome&quot;>Projetado&lt;/span>&lt;div class=&quot;barra-line&quot;>&lt;div class=&quot;barra nova&quot; id=&quot;pj-hbar-n&quot; style=&quot;width:0&quot;>&lt;/div>&lt;span class=&quot;barra-lbl&quot; id=&quot;pj-hlbl-n&quot;>—&lt;/span>&lt;/div>&lt;/div>
