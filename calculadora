&lt;style>
:root{
  --page:#0A1C30; --card:#10263F; --elev:#16304C;
  --line:rgba(255,255,255,.09); --line2:rgba(255,255,255,.16);
  --ink:#FFFFFF; --ink2:#B9C9DA; --mut:#8A97A5;
  --blue:#3E8FD8; --blue-hover:#5AA2E6;
  --track:#1C3D63; --cinza:#8A97A5;
  --verde:#4FD44F;
  --serif:Georgia,'Times New Roman',serif;
  --sans:system-ui,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0}
[hidden]{display:none!important}
html{-webkit-text-size-adjust:100%}
body{background:var(--page);color:var(--ink);font-family:var(--sans);line-height:1.5}
.secao{max-width:1020px;margin:0 auto;padding:40px 18px 48px}

.titulo{font-family:var(--serif);font-weight:700;font-size:clamp(26px,6.5vw,40px);line-height:1.15;text-align:center;margin:0 auto 14px;max-width:700px}
.subtitulo{color:var(--ink2);font-size:clamp(14px,4vw,16.5px);text-align:center;max-width:640px;margin:0 auto 30px;line-height:1.55}

.card{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:22px 18px;box-shadow:0 10px 30px rgba(0,0,0,.28)}
.grid{display:flex;flex-direction:column;gap:14px}
.sec-title{font-size:11px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--mut);margin-bottom:14px}

/* trava: projeção e comparação ficam visíveis (altura estável) mas inativas até preencher */
.trava{opacity:.42;pointer-events:none;filter:saturate(.7)}
.lock-hint{font-size:12px;color:var(--blue-hover);font-weight:600;min-height:20px;margin-bottom:8px}

/* campos */
.field{display:flex;flex-direction:column;gap:6px}
.field + .field{margin-top:14px}
.field label{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--mut)}
.field input{background:var(--elev);border:1px solid var(--line2);border-radius:10px;color:var(--ink);font-size:16px;padding:13px 14px;width:100%}
.field input::placeholder{color:var(--mut)}
.field input:focus{border-color:var(--blue);outline:none}
.reserva-oculta{visibility:hidden}

.res-l{font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--mut);margin-top:18px;padding-top:14px;border-top:1px solid var(--line)}
.res-v{font-size:26px;font-weight:700;font-variant-numeric:tabular-nums;margin-top:2px}
.res-v small{font-size:13px;color:var(--mut);font-weight:600}
.hint{color:var(--mut);font-size:11.5px;margin-top:4px;min-height:17px}
.hint-2l{min-height:34px}

/* sliders */
.slider-row{margin-top:18px}
.slider-row:first-of-type{margin-top:2px}
.slider-head{display:flex;justify-content:space-between;align-items:baseline;gap:10px;margin-bottom:10px}
.slider-head label{font-size:12.5px;color:var(--ink2);font-weight:600}
.slider-val{font-weight:700;font-size:17px;font-variant-numeric:tabular-nums;white-space:nowrap}
input[type=range]{-webkit-appearance:none;appearance:none;width:100%;height:30px;outline:none;cursor:pointer;
  touch-action:none;background-color:transparent;
  background-image:linear-gradient(90deg,var(--track) 0%,var(--track) 100%);
  background-repeat:no-repeat;background-position:center;background-size:100% 6px}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;width:26px;height:26px;border-radius:50%;
  background:var(--blue);border:3px solid var(--page);box-shadow:0 1px 6px rgba(0,0,0,.45);cursor:grab}
input[type=range]::-moz-range-track{height:6px;background:transparent}
input[type=range]::-moz-range-thumb{width:20px;height:20px;border-radius:50%;background:var(--blue);border:3px solid var(--page);cursor:grab}
input[type=range]:focus-visible{outline:2px solid var(--blue-hover);outline-offset:2px}
.slider-minmax{display:flex;justify-content:space-between;font-size:11px;color:var(--mut);margin-top:6px}

.proj-v{font-size:clamp(32px,9vw,42px);font-weight:700;line-height:1.1;margin-top:2px;font-variant-numeric:tabular-nums}

/* comparativo */
.comp-head{display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:16px}
.comp-head .sec-title{margin-bottom:0}
.seg{display:inline-flex;background:var(--elev);border:1px solid var(--line2);border-radius:10px;padding:3px;gap:2px}
.seg button{border:none;background:transparent;color:var(--ink2);font-family:inherit;font-size:12.5px;font-weight:600;padding:7px 14px;border-radius:8px;cursor:pointer;min-width:64px}
.seg button.on{background:var(--blue);color:#fff}
.field .seg{align-self:flex-start}
.barras{display:flex;flex-direction:column;gap:12px;margin-bottom:16px}
.barra-row{display:grid;grid-template-columns:72px 1fr;gap:10px;align-items:center}
.barra-nome{font-size:12px;color:var(--ink2);font-weight:600;text-align:right}
.barra-line{display:flex;align-items:center;gap:8px;min-width:0}
.barra{height:20px;border-radius:0 4px 4px 0;min-width:3px}
.barra.atual{background:var(--cinza);opacity:.55}
.barra.nova{background:var(--blue)}
.barra-lbl{font-size:12px;font-weight:700;white-space:nowrap;font-variant-numeric:tabular-nums}
.tiles{display:grid;grid-template-columns:1fr;gap:10px}
.tile{background:var(--elev);border:1px solid var(--line);border-radius:10px;padding:12px 14px}
.tile .t-l{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--mut);font-weight:700}
.tile .t-v{font-size:21px;font-weight:700;margin-top:3px;font-variant-numeric:tabular-nums}
.t-v.pos{color:var(--verde)}
.sub-comp{font-size:11px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--mut);margin:20px 0 12px;padding-top:16px;border-top:1px solid var(--line)}
.frase{margin-top:14px;padding:13px 15px;background:var(--elev);border-radius:10px;color:var(--ink2);font-size:14px;line-height:1.55;min-height:158px}
.frase b{color:var(--ink)}

/* desktop */
@media (min-width:760px){
  .secao{padding:56px 24px 64px}
  .frase{min-height:96px}
  .card{padding:26px}
  .grid{display:grid;grid-template-columns:1fr 1.3fr;gap:16px;align-items:stretch}
  .tiles{grid-template-columns:repeat(3,1fr)}
}
&lt;/style>
