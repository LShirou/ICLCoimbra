    &lt;div class=&quot;card&quot; id=&quot;pj-card-proj&quot;>
      &lt;div class=&quot;sec-title&quot;>Depois de implementar as estratégias&lt;/div>
      &lt;div class=&quot;lock-hint&quot; id=&quot;pj-lock&quot;>Preencha seus números ao lado para liberar a projeção.&lt;/div>
      &lt;div class=&quot;slider-row&quot;>
        &lt;div class=&quot;slider-head&quot;>&lt;label for=&quot;pj-r-ticket&quot;>Novo valor da consulta&lt;/label>&lt;span class=&quot;slider-val&quot; id=&quot;pj-v-ticket&quot;>—&lt;/span>&lt;/div>
        &lt;input type=&quot;range&quot; id=&quot;pj-r-ticket&quot; min=&quot;0&quot; max=&quot;100&quot; value=&quot;0&quot; disabled aria-label=&quot;Novo valor da consulta&quot;>
        &lt;div class=&quot;slider-minmax&quot;>&lt;span id=&quot;pj-min-t&quot;>—&lt;/span>&lt;span id=&quot;pj-max-t&quot;>—&lt;/span>&lt;/div>
      &lt;/div>
      &lt;div class=&quot;slider-row&quot;>
        &lt;div class=&quot;slider-head&quot;>&lt;label for=&quot;pj-r-pac&quot;>Pacientes por semana com captação&lt;/label>&lt;span class=&quot;slider-val&quot; id=&quot;pj-v-pac&quot;>—&lt;/span>&lt;/div>
        &lt;input type=&quot;range&quot; id=&quot;pj-r-pac&quot; min=&quot;0&quot; max=&quot;100&quot; value=&quot;0&quot; disabled aria-label=&quot;Pacientes por semana com captação&quot;>
        &lt;div class=&quot;slider-minmax&quot;>&lt;span id=&quot;pj-min-p&quot;>—&lt;/span>&lt;span id=&quot;pj-max-p&quot;>—&lt;/span>&lt;/div>
      &lt;/div>
      &lt;div class=&quot;res-l&quot;>Seu faturamento projetado&lt;/div>
      &lt;div class=&quot;proj-v&quot; id=&quot;pj-fat-novo&quot;>—&lt;/div>
      &lt;div class=&quot;hint&quot; id=&quot;pj-sub&quot;>&lt;/div>
      &lt;div class=&quot;res-l&quot;>O valor da sua hora projetado&lt;/div>
      &lt;div class=&quot;res-v&quot; id=&quot;pj-hora-nova&quot;>—&lt;/div>
      &lt;div class=&quot;hint hint-2l&quot; id=&quot;pj-hora-nova-det&quot;>entregando a dieta na hora, direto na consulta&lt;/div>
    &lt;/div>
  &lt;/div>

  &lt;div class=&quot;card&quot; id=&quot;pj-card-comp&quot; style=&quot;margin-top:14px&quot;>
    &lt;div class=&quot;comp-head&quot;>
